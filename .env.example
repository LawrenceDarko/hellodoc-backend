# Django Core
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/hellodoc

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...

# Zoom (JWT or SDK credentials). If using OAuth, replace with appropriate flow.
ZOOM_API_KEY=
ZOOM_API_SECRET=
# Server-to-server OAuth (preferred for production). If using OAuth server-to-server,
# set the client id/secret and optionally account id (account_credentials grant).
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
# Optional: account id for server-to-server apps (use with grant_type=account_credentials)
ZOOM_OAUTH_ACCOUNT_ID=

# Redis (for Celery broker)
REDIS_URL=redis://localhost:6379/0

# Supabase S3-Compatible Storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hellodoc-audio
AWS_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=us-east-1
