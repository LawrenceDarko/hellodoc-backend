# Django Core
SECRET_KEY=your-django-secret-key-here
JWT_SECRET=replace-with-a-long-jwt-signing-secret
DEBUG=False
ALLOW_DEBUG=False
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/hellodoc

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...
TRANSCRIPTION_DAILY_MINUTE_CAP=120

# Sentry
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# Zoom Server-to-Server OAuth (account_credentials grant).
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_ACCOUNT_ID=

# Redis (for Celery broker)
REDIS_URL=redis://localhost:6379/0

# Supabase S3-Compatible Storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hellodoc-audio
AWS_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=us-east-1

# Recall.ai (Bot recording service)
# HOW TO GET CREDENTIALS:
# 1. Sign up at https://app.recall.ai
# 2. Dashboard → API Keys → copy key → paste below
# 3. Dashboard → Webhooks → Add webhook URL:
#    https://your-domain.com/api/webhooks/recall/
# 4. Subscribe to events: bot.in_call_recording, bot.done, bot.fatal_error
# 5. Dashboard → API Keys → create/copy the verification secret → paste below
#    It must start with whsec_.
#    Legacy Recall workspaces created before 2025-12-15 may need the per-webhook
#    Svix secret from the webhook endpoint instead; paste that into
#    RECALL_SVIX_WEBHOOK_SECRET.
#
# FOR LOCAL TESTING:
# Install ngrok: https://ngrok.com
# Run: ngrok http 8000
# Use the ngrok URL as your webhook URL in Recall.ai dashboard
# e.g. https://abc123.ngrok.io/api/webhooks/recall/
RECALL_AI_API_KEY=
RECALL_AI_WEBHOOK_SECRET=
RECALL_SVIX_WEBHOOK_SECRET=
